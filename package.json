{
  "name": "edupangan-ui",
  "version": "1.0.0",
  "description": "UI/UX components for EduPangan - Indramayu Smart Food Village",
  "main": "index.js",
  "scripts": {
    "dev": "next dev",
    "dev:all": "concurrently -k -n WEB,AI -c green,cyan \"npm:dev\" \"npm:ai:worker\"",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate deploy",
    "db:seed": "node prisma/seed.js",
    "db:studio": "prisma studio",
    "ai:worker": "node scripts/ai-worker.js",
    "ai:once": "node scripts/ai-worker.js --once"
  },
  "keywords": [
    "edupangan",
    "smart-village",
    "food-security",
    "ui-components",
    "react",
    "tailwindcss"
  ],
  "author": "EduPangan Team",
  "license": "MIT",
  "dependencies": {
    "@heroicons/react": "^2.2.0",
    "@prisma/client": "^6.16.3",
    "bcryptjs": "^3.0.3",
    "jsonwebtoken": "^9.0.3",
    "mqtt": "^5.3.0",
    "next": "^14.2.33",
    "prisma": "^6.16.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.16",
    "concurrently": "^9.2.1",
    "es-abstract": "^1.24.1",
    "eslint": "^8.56.0",
    "eslint-config-next": "^14.0.0",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.4.0"
  }
}
